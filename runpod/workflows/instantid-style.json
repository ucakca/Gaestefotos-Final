{
  "_meta": {
    "title": "InstantID — Identity-Preserving Style Transfer",
    "description": "Style transfer that preserves facial identity using InstantID + SDXL. Replaces fal-ai/instantid.",
    "author": "gaestefotos.com",
    "version": "1.0.0"
  },
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "_meta": { "title": "Load SDXL Base" },
    "inputs": {
      "ckpt_name": "flux1-dev-fp8.safetensors"
    }
  },
  "2": {
    "class_type": "LoadImage",
    "_meta": { "title": "Face Reference Image" },
    "inputs": {
      "image": "input_image.png"
    }
  },
  "3": {
    "class_type": "InstantIDModelLoader",
    "_meta": { "title": "Load InstantID Adapter" },
    "inputs": {
      "instantid_file": "ip-adapter.bin"
    }
  },
  "4": {
    "class_type": "ControlNetLoader",
    "_meta": { "title": "Load InstantID ControlNet" },
    "inputs": {
      "control_net_name": "instantid-controlnet.safetensors"
    }
  },
  "5": {
    "class_type": "InstantIDFaceAnalysis",
    "_meta": { "title": "Analyze Face" },
    "inputs": {
      "provider": "CPU"
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Style Prompt" },
    "inputs": {
      "text": "{{prompt}}",
      "clip": ["1", 1]
    }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative Prompt" },
    "inputs": {
      "text": "{{negative_prompt}}",
      "clip": ["1", 1]
    }
  },
  "8": {
    "class_type": "ApplyInstantID",
    "_meta": { "title": "Apply InstantID" },
    "inputs": {
      "instantid": ["3", 0],
      "insightface": ["5", 0],
      "control_net": ["4", 0],
      "image": ["2", 0],
      "model": ["1", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "ip_weight": 0.8,
      "cn_strength": 0.65,
      "start_at": 0.0,
      "end_at": 1.0
    }
  },
  "9": {
    "class_type": "EmptyLatentImage",
    "_meta": { "title": "Empty Latent" },
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    }
  },
  "10": {
    "class_type": "KSampler",
    "_meta": { "title": "Sample" },
    "inputs": {
      "model": ["8", 0],
      "positive": ["8", 1],
      "negative": ["8", 2],
      "latent_image": ["9", 0],
      "seed": 42,
      "steps": 30,
      "cfg": 5.0,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 1.0
    }
  },
  "11": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["10", 0],
      "vae": ["1", 2]
    }
  },
  "12": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["11", 0],
      "filename_prefix": "instantid_style"
    }
  }
}
