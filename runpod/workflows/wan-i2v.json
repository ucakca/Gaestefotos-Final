{
  "_meta": {
    "title": "WAN 2.1 Image-to-Video",
    "description": "Generate 480p video from a single image using WAN 2.1 14B. Replaces fal-ai/wan/v2.1/image-to-video.",
    "author": "gaestefotos.com",
    "version": "1.0.0",
    "notes": "WAN 2.1 is natively supported in ComfyUI v0.3.30+. Model loaded from network volume."
  },
  "1": {
    "class_type": "UNETLoader",
    "_meta": { "title": "Load WAN 2.1 I2V Model" },
    "inputs": {
      "unet_name": "wan2.1_i2v_480p_14B_fp8_e4m3fn.safetensors",
      "weight_dtype": "fp8_e4m3fn"
    }
  },
  "2": {
    "class_type": "CLIPLoader",
    "_meta": { "title": "Load WAN CLIP (UMT5-XXL)" },
    "inputs": {
      "clip_name": "umt5_xxl_fp8_e4m3fn_scaled.safetensors",
      "type": "wan"
    }
  },
  "3": {
    "class_type": "VAELoader",
    "_meta": { "title": "Load WAN VAE" },
    "inputs": {
      "vae_name": "wan_2.1_vae.safetensors"
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Positive Prompt" },
    "inputs": {
      "text": "{{prompt}}",
      "clip": ["2", 0]
    }
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative Prompt" },
    "inputs": {
      "text": "static, blurry, distorted, low quality, watermark",
      "clip": ["2", 0]
    }
  },
  "6": {
    "class_type": "LoadImage",
    "_meta": { "title": "Input Image" },
    "inputs": {
      "image": "input_image.png"
    }
  },
  "7": {
    "class_type": "ImageScale",
    "_meta": { "title": "Scale to 832x480 (16:9)" },
    "inputs": {
      "image": ["6", 0],
      "upscale_method": "lanczos",
      "width": 832,
      "height": 480,
      "crop": "center"
    }
  },
  "8": {
    "class_type": "WanImageToVideo",
    "_meta": { "title": "WAN I2V Conditioning" },
    "inputs": {
      "clip_vision_output": ["7", 0],
      "vae": ["3", 0],
      "width": 832,
      "height": 480,
      "length": 81
    }
  },
  "9": {
    "class_type": "BasicScheduler",
    "_meta": { "title": "Scheduler" },
    "inputs": {
      "model": ["1", 0],
      "scheduler": "normal",
      "steps": 30,
      "denoise": 1.0
    }
  },
  "10": {
    "class_type": "BasicGuider",
    "_meta": { "title": "Guider" },
    "inputs": {
      "model": ["1", 0],
      "conditioning": ["4", 0]
    }
  },
  "11": {
    "class_type": "RandomNoise",
    "_meta": { "title": "Random Noise" },
    "inputs": {
      "noise_seed": 42
    }
  },
  "12": {
    "class_type": "SamplerCustomAdvanced",
    "_meta": { "title": "Sampler" },
    "inputs": {
      "noise": ["11", 0],
      "guider": ["10", 0],
      "sampler": {
        "class_type": "KSamplerSelect",
        "inputs": { "sampler_name": "uni_pc_bh2" }
      },
      "sigmas": ["9", 0],
      "latent_image": ["8", 0]
    }
  },
  "13": {
    "class_type": "VAEDecode",
    "_meta": { "title": "Decode Video" },
    "inputs": {
      "samples": ["12", 0],
      "vae": ["3", 0]
    }
  },
  "14": {
    "class_type": "SaveAnimatedWEBP",
    "_meta": { "title": "Save Video as WEBP" },
    "inputs": {
      "images": ["13", 0],
      "filename_prefix": "wan_video",
      "fps": 16,
      "lossless": false,
      "quality": 85,
      "method": "default"
    }
  }
}
